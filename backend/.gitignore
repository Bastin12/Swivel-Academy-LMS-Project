# ============================================================
# SWIVEL ACADEMY — Root .gitignore
# Covers: React/Vite frontend + Node/Express/PostgreSQL backend
# ============================================================


# ─── Dependencies ───────────────────────────────────────────
node_modules/
.pnp
.pnp.js


# ─── Environment Variables (NEVER commit secrets) ───────────
.env
.env.*
!.env.example
!.env.*.example


# ─── Frontend Build Output (Vite) ───────────────────────────
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/build/


# ─── Backend Build Output ───────────────────────────────────
backend/dist/
backend/build/


# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ─── Local / Temp Files ─────────────────────────────────────
*.local
*.tmp
*.temp
.cache/


# ─── OS Generated Files ─────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini


# ─── Editor & IDE ───────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.history/


# ─── Testing & Coverage ─────────────────────────────────────
coverage/
*.lcov
.nyc_output/


# ─── Package Manager Lock Files (keep one, ignore the rest) ─
# Uncomment the one your team does NOT use:
# yarn.lock
# pnpm-lock.yaml


# ─── Database / Seeds (if local dump files exist) ───────────
*.sql
*.dump
*.sqlite
*.sqlite3
*.db


# ─── SSL / Certificates ─────────────────────────────────────
*.pem
*.key
*.crt
*.cert


# ─── Miscellaneous ──────────────────────────────────────────
.eslintcache
.stylelintcache
*.tgz
*.tar.gz
